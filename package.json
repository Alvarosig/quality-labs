{
  "name": "quality-labs",
  "version": "1.0.0",
  "description": "QA portfolio — E2E, API, performance, and BDD testing against the Conduit RealWorld app",
  "scripts": {
    "test:e2e": "npx playwright test --project=e2e",
    "test:e2e:ui": "npx playwright test --project=e2e --ui",
    "test:e2e:codegen": "npx playwright codegen https://conduit.bondaracademy.com",
    "test:api": "npx playwright test --project=api",
    "test": "npx playwright test",
    "test:bdd": "npx cucumber-js",
    "report": "npx playwright show-report",
    "har:record": "npx playwright test --project=e2e tests/e2e/har-example.spec.ts",
    "har:convert": "node scripts/har-converter.js",
    "format": "prettier --write ."
  },
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "e2e",
    "api-testing"
  ],
  "author": "Alvaro",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "prettier": "3.8.1",
    "ts-node": "^10.9.2"
  }
}
